# ChatNAV API Configuration
# Copy to .env and adjust as needed

# Path to the pipeline repo root (where main.nf lives)
# CHATNAV_PIPELINE_ROOT=/path/to/ChatNAV

# Directory for uploads, results, logs, and SQLite DB
# CHATNAV_DATA_DIR=./data

# SQLite database URL
# CHATNAV_DATABASE_URL=sqlite:///./data/chatnav.db

# Nextflow binary path
# CHATNAV_NEXTFLOW_BIN=nextflow

# Nextflow profile (local, aws, test)
# CHATNAV_NEXTFLOW_PROFILE=local

# Max file upload size in MB
# CHATNAV_MAX_UPLOAD_SIZE_MB=500

# Max concurrent pipeline runs
# CHATNAV_MAX_CONCURRENT_JOBS=3
