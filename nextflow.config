nextflow.enable.dsl = 2

params {
    // ── Patient identity ──
    patient_id        = 'patient_001'
    tumor_type        = null      // e.g. 'SKCM', 'NSCLC', 'PDAC'

    // ── Input files (null = not provided → entry point detection) ──
    tumor_fastq_1     = null
    tumor_fastq_2     = null
    normal_fastq_1    = null
    normal_fastq_2    = null
    tumor_bam         = null
    normal_bam        = null
    vcf               = null
    cnv_segments      = null
    fusions           = null
    rnaseq_fastq_1    = null
    rnaseq_fastq_2    = null
    expression        = null
    hla_alleles       = null
    candidates_fasta  = null
    candidates_meta   = null
    binding_predictions = null

    // ── Feature flags ──
    parabricks         = false
    structural_scoring = false

    // ── Scoring configuration ──
    weight_profile           = 'high_tmb'    // high_tmb | low_tmb | research
    top_n                    = 20
    min_ccf                  = 0.5
    min_tpm                  = 1.0
    binding_rank_threshold   = 0.02
    truncal_ccf              = 0.8

    // ── Reference paths ──
    reference_genome         = null
    reference_genome_index   = null
    vep_cache                = null
    salmon_index             = null
    gencode_gtf              = null
    dbsnp                    = null
    known_indels             = null
    gnomad                   = null
    human_proteome           = null
    shared_neoantigens_table = "${projectDir}/reference/shared_neoantigens/shared_neoantigens.tsv"
    gtex_priors_table        = "${projectDir}/reference/gtex_priors/gtex_median_tpm_by_type.tsv"
    scoring_weights          = "${projectDir}/conf/scoring_weights.yaml"
    utr_5prime               = "${projectDir}/reference/utr_library/utr_5prime.fasta"
    utr_3prime               = "${projectDir}/reference/utr_library/utr_3prime.fasta"
    signal_peptides          = "${projectDir}/reference/signal_peptides.fasta"
    hla_heavy_chains         = "${projectDir}/reference/hla_sequences/hla_heavy_chains.fasta"

    // ── mRNA design ──
    poly_a_length            = 120
    codon_table              = 'human'

    // ── Output ──
    outdir                   = './results'
}

// ── Profile includes ──
includeConfig 'conf/base.config'

profiles {
    local {
        includeConfig 'conf/local.config'
    }
    aws {
        includeConfig 'conf/aws.config'
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// ── Manifest ──
manifest {
    name            = 'neoantigen-vaccine-pipeline'
    author          = 'McClain Thiel'
    description     = 'Personalized mRNA neoantigen vaccine design pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '0.1.0'
}

// ── Timeline / report ──
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
