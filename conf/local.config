docker {
    enabled   = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    // Override resources for local machine
    withLabel: process_high {
        cpus   = { Math.min(8, 32 * task.attempt) }
        memory = { Math.min(32.GB, 240.GB * task.attempt) }
        time   = 72.h
    }
    withLabel: process_medium {
        cpus   = { Math.min(4, 8 * task.attempt) }
        memory = { Math.min(16.GB, 32.GB * task.attempt) }
        time   = 24.h
    }
    withLabel: process_low {
        cpus   = { Math.min(2, 2 * task.attempt) }
        memory = { Math.min(8.GB, 8.GB * task.attempt) }
        time   = 12.h
    }
    withLabel: process_gpu {
        // No GPU locally by default — fall back to CPU
        accelerator = 0
    }
}

executor {
    name   = 'local'
    cpus   = 8
    memory = '32 GB'
}
